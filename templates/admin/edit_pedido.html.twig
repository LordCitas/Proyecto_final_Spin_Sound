{% extends 'base.html.twig' %}

{% block title %}Editar Pedido #{{ pedido.id }} - Panel Admin{% endblock %}

{% block body %}
<main class="flex-1 animate-reveal">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="max-w-3xl mx-auto">
            <div class="mb-8">
                <div class="flex items-center gap-3 mb-4">
                    <a href="{{ path('app_admin_panel') }}" class="p-2 hover:bg-surface-dark rounded-lg transition-colors" title="Volver">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
                            <path d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z"></path>
                        </svg>
                    </a>
                    <h1 class="text-3xl font-bold">Editar Pedido #{{ pedido.id }}</h1>
                </div>
            </div>

            <div class="bg-surface-dark border border-gray-800 rounded-lg p-8">
                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('edit-pedido' ~ pedido.id) }}">

                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-on-surface-muted-dark mb-2">Cliente</label>
                            <input type="text" value="{{ pedido.cliente.nombre }} ({{ pedido.cliente.email }})" class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-400" readonly disabled>
                            <p class="mt-1 text-xs text-on-surface-muted-dark">El cliente no se puede cambiar por seguridad.</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-on-surface-muted-dark mb-2">Fecha</label>
                            <input type="text" value="{{ pedido.fecha|date('d/m/Y H:i') }}" class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-gray-400" readonly disabled>
                        </div>

                        <div>
                            <label for="total" class="block text-sm font-medium mb-2">Total (€)</label>
                            <input type="number" step="0.01" name="total" id="total" value="{{ pedido.total }}" class="w-full px-4 py-2 bg-white border border-gray-300 rounded-lg text-black focus:ring-2 focus:ring-[#e00000] focus:border-[#e00000]" required>
                        </div>

                        <div class="pt-4 border-t border-gray-800">
                            <h3 class="text-lg font-bold mb-4">Detalle de Productos</h3>
                            <div class="space-y-4">
                                {% for detalle in pedido.detalles %}
                                <div class="flex items-center justify-between p-4 bg-black/20 rounded-lg">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-gray-800 rounded flex items-center justify-center overflow-hidden">
                                            {% if detalle.vinilo and detalle.vinilo.imagen %}
                                                <img src="{{ detalle.vinilo.imagen }}" class="w-full h-full object-cover">
                                            {% else %}
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="text-gray-600">
                                                    <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm40-96a40,40,0,1,1-40-40A40,40,0,0,1,168,120Zm-16,0a24,24,0,1,0-24,24A24,24,0,0,0,152,120Z"></path>
                                                </svg>
                                            {% endif %}
                                        </div>
                                        <div>
                                            <p class="font-medium">{{ detalle.vinilo ? detalle.vinilo.titulo : 'Producto Eliminado' }}</p>
                                            <p class="text-sm text-on-surface-muted-dark">Cantidad: {{ detalle.cantidad }}</p>
                                        </div>
                                    </div>
                                    <p class="font-bold">{{ (detalle.precio * detalle.cantidad)|number_format(2, ',', '.') }} €</p>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 flex gap-4">
                        <button type="submit" class="flex-1 bg-[#e00000] hover:bg-[#c00000] text-white font-bold py-3 rounded-lg transition-colors">
                            Guardar Cambios
                        </button>
                        <a href="{{ path('app_admin_panel') }}" class="flex-1 bg-gray-700 hover:bg-gray-600 text-white font-bold py-3 rounded-lg transition-colors text-center">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>

            <div class="mt-6 text-center text-sm text-on-surface-muted-dark">
                <p>Auditoría: Creado el {{ pedido.createdAt|date('d/m/Y H:i') }}{% if pedido.modifiedAt %} | Modificado el {{ pedido.modifiedAt|date('d/m/Y H:i') }}{% endif %}</p>
            </div>
        </div>
    </div>
</main>
{% endblock %}

